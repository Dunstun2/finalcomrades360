import React, { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { Button } from '../../../components/ui/button';
import { Input } from '../../../components/ui/input';
import { useToast } from '../../../components/ui/use-toast';
import { fastFoodService } from '../../../services/fastFoodService';
import { 
  FaArrowLeft, 
  FaPlus, 
  FaSearch, 
  FaEye, 
  FaEdit, 
  FaTrash,
  FaUtensils,
  FaClock,
  FaMapMarkerAlt,
  FaSpinner,
  FaTimes
} from 'react-icons/fa';

const FastFoodManagement = () => {
  const navigate = useNavigate();
  const { toast } = useToast();
  const [fastFoods, setFastFoods] = useState([]);
  const [loading, setLoading] = useState(true);
  const [searchTerm, setSearchTerm] = useState('');
  const [selectedCategory, setSelectedCategory] = useState('');
  const [showForm, setShowForm] = useState(false);

  const categories = [
    'Burgers & Sandwiches',
    'Pizza',
    'Chicken & Wings',
    'Rice & Pilau',
    'Biryani & Curry',
    'Fast Foods',
    'Snacks & Sides',
    'Beverages',
    'Desserts',
    'Chinese Food',
    'Indian Food',
    'Mexican Food'
  ];

  // Fetch fast food items
  const fetchFastFoods = async () => {
    try {
      setLoading(true);
      const response = await fastFoodService.getAllFastFoods();
      if (response.success) {
        setFastFoods(response.data.fastFoods || []);
      }
    } catch (error) {
      console.error('Error fetching fast foods:', error);
      toast({
        title: 'Error',
        description: 'Failed to load fast food items',
        variant: 'destructive'
      });
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchFastFoods();
  }, []);

  // Filter fast foods based on search and category
  const filteredFastFoods = fastFoods.filter(fastFood => {
    const matchesSearch = fastFood.name.toLowerCase().includes(searchTerm.toLowerCase()) ||
                         fastFood.shortDescription.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesCategory = selectedCategory === '' || fastFood.category === selectedCategory;
    return matchesSearch && matchesCategory;
  });

  // Handle delete
  const handleDelete = async (id) => {
    if (window.confirm('Are you sure you want to delete this fast food item?')) {
      try {
        await fastFoodService.deleteFastFood(id);
        toast({
          title: 'Success',
          description: 'Fast food item deleted successfully'
        });
        fetchFastFoods();
      } catch (error) {
        toast({
          title: 'Error',
          description: 'Failed to delete fast food item',
          variant: 'destructive'
        });
      }
    }
  };

  // Get availability status
  const getAvailabilityStatus = (fastFood) => {
    return fastFoodService.getAvailabilityStatus(fastFood);
  };

  // Format price
  const formatPrice = (fastFood) => {
    return fastFoodService.formatPrice(fastFood);
  };

  // Format preparation time
  const formatPreparationTime = (minutes) => {
    return fastFoodService.formatPreparationTime(minutes);
  };

  // Get status color
  const getStatusColor = (fastFood) => {
    if (!fastFood.isActive) return 'bg-gray-100 text-gray-600';
    const availability = getAvailabilityStatus(fastFood);
    return availability.isAvailable ? 'bg-green-100 text-green-600' : 'bg-yellow-100 text-yellow-600';
  };

  if (showForm) {
    return (
      <div className="min-h-screen bg-gray-50 p-6">
        <div className="max-w-6xl mx-auto">
          <div className="mb-6 flex items-center">
            <Button
              onClick={() => setShowForm(false)}
              className="mr-4 bg-gray-600 hover:bg-gray-700"
            >
              <FaArrowLeft className="mr-2" />
              Back to FastFood Management
            </Button>
            <h1 className="text-2xl font-bold text-gray-800">Create Fast Food Item</h1>
          </div>
          
          {/* Import and render the FastFood form component here */}
          <div className="bg-white rounded-lg shadow-lg p-6">
            <p className="text-gray-600 text-center py-12">
              FastFood form will be rendered here when properly integrated.
              You can navigate to the form directly at <code>/dashboard/fastfood/create</code>
            </p>
            <div className="flex justify-center">
              <Button
                onClick={() => navigate('/dashboard/fastfood/create')}
                className="bg-blue-600 hover:bg-blue-700"
              >
                Go to FastFood Form
              </Button>
            </div>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50 p-6">
      <div className="max-w-6xl mx-auto">
        {/* Header */}
        <div className="mb-6 flex items-center">
          <Button
            onClick={() => navigate('/dashboard/product-management')}
            className="mr-4 bg-gray-600 hover:bg-gray-700"
          >
            <FaArrowLeft className="mr-2" />
            Back to Product Management
          </Button>
          <div>
            <h1 className="text-2xl font-bold text-gray-800 flex items-center">
              <FaUtensils className="mr-3 text-orange-500" />
              FastFood Management
            </h1>
            <p className="text-gray-600">Manage your fast food items and menus</p>
          </div>
        </div>

        {/* Action Bar */}
        <div className="bg-white rounded-lg shadow-sm p-6 mb-6">
          <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div className="flex flex-col md:flex-row gap-4 flex-1">
              {/* Search */}
              <div className="relative flex-1">
                <FaSearch className="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400" />
                <Input
                  placeholder="Search fast food items..."
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                  className="pl-10"
                />
              </div>
              
              {/* Category Filter */}
              <select
                value={selectedCategory}
                onChange={(e) => setSelectedCategory(e.target.value)}
                className="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <option value="">All Categories</option>
                {categories.map(category => (
                  <option key={category} value={category}>{category}</option>
                ))}
              </select>
            </div>
            
            {/* Add New Button */}
            <Button
              onClick={() => navigate('/dashboard/fastfood/create')}
              className="bg-orange-600 hover:bg-orange-700 whitespace-nowrap"
            >
              <FaPlus className="mr-2" />
              Add FastFood Item
            </Button>
          </div>
        </div>

        {/* Stats Cards */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
          <div className="bg-white rounded-lg shadow-sm p-6">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-gray-600">Total Items</p>
                <p className="text-2xl font-bold text-gray-900">{fastFoods.length}</p>
              </div>
              <FaUtensils className="text-orange-500 text-2xl" />
            </div>
          </div>
          
          <div className="bg-white rounded-lg shadow-sm p-6">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-gray-600">Active Items</p>
                <p className="text-2xl font-bold text-green-600">
                  {fastFoods.filter(item => item.isActive).length}
                </p>
              </div>
              <FaEye className="text-green-500 text-2xl" />
            </div>
          </div>
          
          <div className="bg-white rounded-lg shadow-sm p-6">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-gray-600">Categories</p>
                <p className="text-2xl font-bold text-blue-600">
                  {new Set(fastFoods.map(item => item.category)).size}
                </p>
              </div>
              <FaSearch className="text-blue-500 text-2xl" />
            </div>
          </div>
          
          <div className="bg-white rounded-lg shadow-sm p-6">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-gray-600">Available Now</p>
                <p className="text-2xl font-bold text-purple-600">
                  {fastFoods.filter(item => {
                    const availability = getAvailabilityStatus(item);
                    return availability.isAvailable;
                  }).length}
                </p>
              </div>
              <FaClock className="text-purple-500 text-2xl" />
            </div>
          </div>
        </div>

        {/* FastFood List */}
        <div className="bg-white rounded-lg shadow-sm">
          <div className="p-6 border-b border-gray-200">
            <h2 className="text-lg font-semibold text-gray-800">
              FastFood Items ({filteredFastFoods.length})
            </h2>
          </div>
          
          {loading ? (
            <div className="flex justify-center items-center py-12">
              <FaSpinner className="animate-spin text-blue-500 text-2xl" />
              <span className="ml-2 text-gray-600">Loading fast food items...</span>
            </div>
          ) : filteredFastFoods.length === 0 ? (
            <div className="text-center py-12">
              <FaUtensils className="mx-auto text-gray-400 text-4xl mb-4" />
              <h3 className="text-lg font-medium text-gray-900 mb-2">No fast food items found</h3>
              <p className="text-gray-500 mb-6">
                {searchTerm || selectedCategory 
                  ? 'Try adjusting your search or filter criteria'
                  : 'Get started by adding your first fast food item'
                }
              </p>
              {!searchTerm && !selectedCategory && (
                <Button
                  onClick={() => navigate('/dashboard/fastfood/create')}
                  className="bg-orange-600 hover:bg-orange-700"
                >
                  <FaPlus className="mr-2" />
                  Add FastFood Item
                </Button>
              )}
            </div>
          ) : (
            <div className="overflow-x-auto">
              <table className="min-w-full divide-y divide-gray-200">
                <thead className="bg-gray-50">
                  <tr>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Item
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Category
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Price
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Availability
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Prep Time
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Status
                    </th>
                    <th className="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Actions
                    </th>
                  </tr>
                </thead>
                <tbody className="bg-white divide-y divide-gray-200">
                  {filteredFastFoods.map((fastFood) => {
                    const priceInfo = formatPrice(fastFood);
                    const availability = getAvailabilityStatus(fastFood);
                    
                    return (
                      <tr key={fastFood._id} className="hover:bg-gray-50">
                        <td className="px-6 py-4 whitespace-nowrap">
                          <div className="flex items-center">
                            {fastFood.mainImage && (
                              <img
                                className="h-12 w-12 rounded-lg object-cover mr-4"
                                src={fastFood.mainImage}
                                alt={fastFood.name}
                              />
                            )}
                            <div>
                              <div className="text-sm font-medium text-gray-900">
                                {fastFood.name}
                              </div>
                              <div className="text-sm text-gray-500 truncate max-w-xs">
                                {fastFood.shortDescription}
                              </div>
                            </div>
                          </div>
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap">
                          <span className="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                            {fastFood.category}
                          </span>
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap">
                          <div className="text-sm text-gray-900">
                            {priceInfo.discountPercentage > 0 ? (
                              <div>
                                <span className="text-green-600 font-medium">
                                  KSh {priceInfo.finalPrice.toFixed(2)}
                                </span>
                                <span className="text-gray-500 line-through ml-2">
                                  KSh {priceInfo.originalPrice.toFixed(2)}
                                </span>
                              </div>
                            ) : (
                              <span className="font-medium">
                                KSh {priceInfo.originalPrice.toFixed(2)}
                              </span>
                            )}
                          </div>
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap">
                          <div className="text-sm text-gray-900">
                            <div className="flex items-center">
                              {availability.isAvailable ? (
                                <FaClock className="text-green-500 mr-2" />
                              ) : (
                                <FaTimes className="text-red-500 mr-2" />
                              )}
                              {availability.isAvailable ? 'Available' : 'Unavailable'}
                            </div>
                            {!availability.isAvailable && availability.reason && (
                              <div className="text-xs text-gray-500 mt-1">
                                {availability.reason}
                              </div>
                            )}
                          </div>
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                          <div className="flex items-center">
                            <FaClock className="text-blue-500 mr-2" />
                            {formatPreparationTime(fastFood.preparationTimeMinutes)}
                          </div>
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap">
                          <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${getStatusColor(fastFood)}`}>
                            {fastFood.isActive ? 'Active' : 'Inactive'}
                          </span>
                        </td>
                        <td className="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                          <div className="flex justify-end space-x-2">
                            <Button
                              size="sm"
                              variant="outline"
                              onClick={() => navigate(`/dashboard/fastfood/view/${fastFood._id}`)}
                            >
                              <FaEye className="text-blue-500" />
                            </Button>
                            <Button
                              size="sm"
                              variant="outline"
                              onClick={() => navigate(`/dashboard/fastfood/edit/${fastFood._id}`)}
                            >
                              <FaEdit className="text-green-500" />
                            </Button>
                            <Button
                              size="sm"
                              variant="outline"
                              onClick={() => handleDelete(fastFood._id)}
                            >
                              <FaTrash className="text-red-500" />
                            </Button>
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </div>
  );
};

export default FastFoodManagement;